---
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Blessing Kodze — Software Engineer & Founder",
  description = "I design and engineer digital products that are fast, beautiful, and built to last. Software engineer and founder based in Johannesburg, building for Africa.",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--font-Inter" />
  </head>
  <body class="is-loading">
    <!-- ── Loading Screen ── -->
    <div id="loader" aria-hidden="true">
      <div class="loader-half loader-left">
        <span class="loader-firstname">BLESSING</span>
      </div>
      <div class="loader-half loader-right">
        <span class="loader-lastname">KODZE</span>
      </div>
      <div class="loader-nicknames">
        <span class="loader-nickname"></span>
      </div>
    </div>

    <slot />
  </body>
</html>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  /* ── SplitText utility (manual, no paid plugin) ── */
  function splitTextIntoChars(element: Element): NodeListOf<Element> {
    const html = element.innerHTML;
    const parts: string[] = [];
    let buffer = "";

    for (let i = 0; i < html.length; i++) {
      if (html[i] === "<") {
        // flush buffered text as individual char spans
        if (buffer) {
          for (const ch of buffer) {
            parts.push(
              ch === " "
                ? '<span class="split-char">\u00A0</span>'
                : `<span class="split-char">${ch}</span>`
            );
          }
          buffer = "";
        }
        // copy the whole tag as-is
        const end = html.indexOf(">", i);
        parts.push(html.substring(i, end + 1));
        i = end;
      } else {
        buffer += html[i];
      }
    }
    // flush remaining text
    if (buffer) {
      for (const ch of buffer) {
        parts.push(
          ch === " "
            ? '<span class="split-char">\u00A0</span>'
            : `<span class="split-char">${ch}</span>`
        );
      }
    }

    element.innerHTML = parts.join("");
    return element.querySelectorAll(".split-char");
  }

  /* ── Loader timeline ── */
  const loader = document.getElementById("loader");
  const nicknames = ["chinxeleer", "Autumn leaf", "BK"];

  if (loader) {
    const nicknameEl = loader.querySelector(".loader-nickname") as HTMLElement;
    const firstname = loader.querySelector(".loader-firstname") as HTMLElement;
    const lastname = loader.querySelector(".loader-lastname") as HTMLElement;

    const tl = gsap.timeline({
      onComplete: () => {
        loader.remove();
        document.body.classList.remove("is-loading");
        initPageAnimations();
      },
    });

    // ── Phase 1: Cycle through nicknames ──
    nicknames.forEach((name) => {
      tl.call(() => {
        nicknameEl.textContent = name;
      })
        .fromTo(
          nicknameEl,
          { y: 35, opacity: 0, scale: 0.95 },
          { y: 0, opacity: 1, scale: 1, duration: 0.3, ease: "power2.out" }
        )
        .to(nicknameEl, {
          y: -30,
          opacity: 0,
          scale: 0.95,
          duration: 0.25,
          ease: "power2.in",
          delay: 0.3,
        });
    });

    // ── Phase 2: Hide nicknames, reveal full name ──
    tl.set(nicknameEl, { display: "none" })
      .fromTo(
        [firstname, lastname],
        { y: 25, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power3.out",
          stagger: 0.08,
        }
      )

      // ── Phase 3: Hold, then split ──
      .to({}, { duration: 0.45 })
      .to(".loader-left", {
        xPercent: -100,
        duration: 0.8,
        ease: "power4.inOut",
      })
      .to(
        ".loader-right",
        { xPercent: 100, duration: 0.8, ease: "power4.inOut" },
        "<"
      );
  } else {
    document.body.classList.remove("is-loading");
    initPageAnimations();
  }

  /* ── Page animation system ── */
  function initPageAnimations() {
    // ── SplitText character animations ──
    document.querySelectorAll("[data-split-text]").forEach((el, index) => {
      const chars = splitTextIntoChars(el);
      gsap.from(chars, {
        y: 70,
        opacity: 0,
        rotateX: -40,
        stagger: 0.02,
        duration: 0.7,
        ease: "power3.out",
        delay: 0.15 + index * 0.25,
      });
    });

    // ── Nav entrance ──
    gsap.from('[data-animate="nav"]', {
      y: -20,
      opacity: 0,
      duration: 0.6,
      stagger: 0.08,
      ease: "power2.out",
    });

    // ── Hero secondary elements ──
    gsap.from('[data-animate="hero"]', {
      y: 30,
      opacity: 0,
      duration: 0.7,
      stagger: 0.08,
      ease: "power2.out",
      delay: 0.4,
    });

    gsap.from('[data-animate="hero-secondary"]', {
      y: 20,
      opacity: 0,
      duration: 0.6,
      stagger: 0.06,
      ease: "power2.out",
      delay: 0.8,
    });

    // ── Scroll-triggered: fade up ──
    document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: "top 88%" },
        y: 50,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      });
    });

    // ── Scroll-triggered: stagger children ──
    document
      .querySelectorAll('[data-animate="stagger"]')
      .forEach((container) => {
        const items = container.querySelectorAll("[data-stagger-item]");
        if (items.length === 0) return;
        gsap.from(items, {
          scrollTrigger: { trigger: container, start: "top 88%" },
          y: 40,
          opacity: 0,
          duration: 0.6,
          stagger: 0.1,
          ease: "power2.out",
        });
      });

    // ── Scroll-triggered: slide from left ──
    document.querySelectorAll('[data-animate="slide-left"]').forEach((el) => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: "top 85%" },
        x: -60,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      });
    });

    // ── Scroll-triggered: slide from right ──
    document.querySelectorAll('[data-animate="slide-right"]').forEach((el) => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: "top 85%" },
        x: 60,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      });
    });
  }
</script>
