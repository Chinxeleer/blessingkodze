---
import { ArrowDownRight, ArrowUpRight } from "@lucide/astro";

const currentYear = new Date().getFullYear();
---

<section
  class="relative isolate min-h-[calc(100vh-80px)] flex flex-col justify-center py-10 md:py-16 overflow-hidden"
>
  <!-- Subtle backdrop grid -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="relative z-10 grid grid-cols-12 gap-x-5 gap-y-8 md:gap-x-8 md:gap-y-10 items-start">
    <!-- ── Row 1 Left: Label + Heading ── -->
    <div class="col-span-12 md:col-span-7 order-2 md:order-1">
      <div class="font-mono uppercase tracking-[0.28em] text-[10px] text-foreground/60 mb-5" data-animate="hero">
        <div>01/</div>
        <div class="mt-2 text-foreground/45 tracking-[0.26em]">From Johannesburg<br />with conviction</div>
      </div>

      <h1
        data-split-text
        class="text-foreground font-black uppercase leading-[0.88] tracking-[-0.04em]"
        style="font-size: clamp(3rem, 8.5vw, 7.5rem);"
      >
        SOFTWARE<br />ENGINEER
      </h1>

      <div class="mt-5 flex flex-wrap gap-2" data-animate="hero">
        <a href="#tech" class="pill">Astro</a>
        <a href="#tech" class="pill">TypeScript</a>
        <a href="#tech" class="pill">React</a>
        <a href="#tech" class="pill">AI / ML</a>
        <a href="#tech" class="pill">Rust</a>
      </div>
    </div>

    <!-- ── Row 1 Right: Status + Info ── -->
    <div class="col-span-12 md:col-span-5 order-1 md:order-2 flex flex-col items-start md:items-end gap-3">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-foreground/15 bg-foreground/5 px-3 py-1.5"
        data-animate="hero"
      >
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        <span class="text-[9px] font-mono uppercase leading-tight tracking-[0.18em] text-foreground/60">
          Open for work
        </span>
      </div>

      <div class="font-mono uppercase tracking-[0.28em] text-[10px] text-foreground/55 md:text-right" data-animate="hero">
        <div>Founder &amp; Engineer</div>
        <div class="mt-1.5 text-foreground/40 tracking-[0.26em]">
          Based in Johannesburg, ZA
        </div>
      </div>
    </div>

    <!-- ── Row 2 Left: Description ── -->
    <div class="col-span-12 md:col-span-7 order-3">
      <div class="grid grid-cols-12 items-start gap-3" data-animate="hero-secondary">
        <div class="col-span-1 text-foreground/50 text-lg leading-none select-none font-mono pt-0.5">
          <span aria-hidden="true">→</span>
        </div>
        <div class="col-span-11 md:col-span-8">
          <p class="text-[11px] font-mono uppercase tracking-[0.22em] text-foreground/65 leading-relaxed">
            I design and engineer digital<br />
            products that are fast, beautiful,<br />
            and built to last.
          </p>
          <div class="mt-3 text-[10px] font-mono uppercase tracking-[0.24em] text-foreground/40">
            Open for freelance / full-time
          </div>
        </div>
      </div>
    </div>

    <!-- ── Row 2 Right: Name + Year + CTA ── -->
    <div class="col-span-12 md:col-span-5 order-4 flex flex-col items-start md:items-end gap-5">
      <div
        data-split-text
        class="text-left md:text-right text-foreground font-black uppercase leading-[0.88] tracking-[-0.05em]"
        style="font-size: clamp(3rem, 7vw, 6.2rem);"
      >
        BLESSING<br />KODZE
      </div>

      <div class="text-left md:text-right text-[10px] font-mono uppercase tracking-[0.26em] text-foreground/40" data-animate="hero-secondary">
        {currentYear} Portfolio
      </div>

      <div class="flex gap-3" data-animate="hero-secondary">
        <a
          href="#about"
          class="group inline-flex items-center gap-2 rounded-full border border-foreground/15 bg-transparent px-4 py-2.5 text-[10px] font-mono uppercase tracking-[0.24em] text-foreground/70 transition-all duration-200 hover:border-foreground/40 hover:bg-foreground/5 hover:text-foreground"
        >
          <span>About me</span>
          <ArrowDownRight class="size-3.5 transition-transform group-hover:translate-x-0.5 group-hover:translate-y-0.5" />
        </a>
        <a
          href="mailto:blessingeleer@gmail.com"
          class="group inline-flex items-center gap-2 rounded-full bg-primary px-4 py-2.5 text-[10px] font-mono uppercase tracking-[0.24em] text-primary-foreground transition-all duration-200 hover:bg-primary/85"
        >
          <span>Contact</span>
          <ArrowUpRight class="size-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
        </a>
      </div>
    </div>

    <!-- ── Bottom row: Credit ── -->
    <div class="col-span-12 order-5 flex justify-end" data-animate="hero-secondary">
      <div class="text-[10px] font-mono uppercase tracking-[0.28em] text-foreground/35">
        Design &amp; code by Blessing
      </div>
    </div>
  </div>
</section>
