---
import { Image } from "astro:assets";

import astroLogo from "../assets/logos/astro.png";
import jsLogo from "../assets/logos/javascript.svg";
import rustLogo from "../assets/logos/rust.png";
import tsLogo from "../assets/logos/ts.png";

const stack = [
  { name: "Astro", logo: astroLogo },
  { name: "TypeScript", logo: tsLogo },
  { name: "JavaScript", logo: jsLogo },
  { name: "Rust", logo: rustLogo },
];
---

<section id="tech" class="py-20 md:py-32">
  <h2 class="mb-12 md:mb-16" data-animate="fade-up">Technical Stack</h2>

  <div
    class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6 max-w-5xl mx-auto"
    data-animate="stagger"
  >
    {
      stack.map((tech) => (
        <div class="tech-card" data-stagger-item>
          <Image
            src={tech.logo}
            alt={`${tech.name} logo`}
            width={48}
            height={48}
            class="h-12 w-auto object-contain"
          />
          <span>{tech.name}</span>
        </div>
      ))
    }

    <!-- React (inline SVG) -->
    <div class="tech-card" data-stagger-item>
      <svg
        class="h-12 w-12"
        viewBox="-11.5 -10.232 23 20.463"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
      >
        <circle r="2.05" fill="#61DAFB" />
        <g stroke="#61DAFB" stroke-width="1">
          <ellipse rx="11" ry="4.2" />
          <ellipse rx="11" ry="4.2" transform="rotate(60)" />
          <ellipse rx="11" ry="4.2" transform="rotate(120)" />
        </g>
      </svg>
      <span>React</span>
    </div>

    <!-- Python (inline SVG) -->
    <div class="tech-card" data-stagger-item>
      <svg
        class="h-12 w-12"
        viewBox="0 0 110 110"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <linearGradient id="pyBlue" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#5A9FD4" />
            <stop offset="100%" stop-color="#306998" />
          </linearGradient>
          <linearGradient id="pyYellow" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#FFD43B" />
            <stop offset="100%" stop-color="#FFE873" />
          </linearGradient>
        </defs>
        <path
          d="M54.9 0C26.7 0 28.5 11.9 28.5 11.9l.03 12.3h26.9v3.7H17.1S0 25.1 0 53.6s14.9 27.5 14.9 27.5h8.9V68.3s-.5-14.9 14.7-14.9h25.3s14.2.2 14.2-13.7V14.6S80.1 0 54.9 0zM39.8 8.4a4.8 4.8 0 1 1 0 9.6 4.8 4.8 0 0 1 0-9.6z"
          fill="url(#pyBlue)"
        />
        <path
          d="M55.1 110c28.2 0 26.4-11.9 26.4-11.9l-.03-12.3H54.6v-3.7h38.3S110 84.9 110 56.4s-14.9-27.5-14.9-27.5h-8.9v12.8s.5 14.9-14.7 14.9H46.2s-14.2-.2-14.2 13.7v25.1S29.9 110 55.1 110zm15.1-8.4a4.8 4.8 0 1 1 0-9.6 4.8 4.8 0 0 1 0 9.6z"
          fill="url(#pyYellow)"
        />
      </svg>
      <span>Python</span>
    </div>
  </div>
</section>
